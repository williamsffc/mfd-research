---
// Parity port of legacy static `terms-of-service/index.html`.
import { Fragment } from 'astro/jsx-runtime';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout>
  <Fragment slot="head">
  <title>Terms of Service | MFD Research</title>
  <meta name="description" content="Terms of Service for MFD Research website use." />
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; script-src 'self'; img-src 'self' data: https://mfdresearch.com; connect-src 'self';" />

  <link rel="stylesheet" href="../style.css">
  <style>
    body {
      background: var(--bg);
      color: var(--text-primary);
      line-height: 1.65;
      padding: 0;
      margin: 0;
    }
    .wrap {
      max-width: 860px;
      margin: 0 auto;
      padding: 32px 20px 64px;
    }
    .top {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 18px;
      text-decoration: none;
      color: var(--navy);
    }
    .top img {
      width: 46px;
      height: 46px;
      border-radius: 50%;
      border: 1px solid var(--border);
    }
    .legal-card {
      background: var(--bg-white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 40px;
      box-shadow: var(--shadow-md);
    }
    h1 {
      margin: 0 0 8px;
      font-size: 2.25rem;
      color: var(--navy);
      font-family: 'Syne', sans-serif;
    }
    h2 {
      margin: 32px 0 12px;
      font-size: 1.25rem;
      color: var(--navy);
      font-family: 'Syne', sans-serif;
    }
    p, li { color: var(--text-secondary); }
    ul { padding-left: 20px; margin-bottom: 16px; }
    li { margin-bottom: 8px; }
    .meta {
      margin-top: 0;
      color: var(--green);
      font-weight: 600;
      font-size: 0.9rem;
    }
    .home-btn {
      display: inline-block;
      margin-top: 32px;
      text-decoration: none;
      color: #fff;
      background: var(--navy);
      border-radius: 99px;
      padding: 12px 24px;
      font-weight: 600;
      transition: transform 0.2s ease, background 0.2s ease;
    }
    .home-btn:hover {
      background: var(--navy-light);
      transform: translateY(-2px);
    }
  </style>
  </Fragment>
  <main class="wrap">
    <a class="top" href="../" aria-label="Return to home page">
      <img src="../assets/mfd-logo.jpg" alt="MFD Research logo" />
      <strong>MFD Research</strong>
    </a>

    <article class="legal-card">
      <h1>Terms of Service</h1>
      <p class="meta">Last updated: March 6, 2026</p>

      <h2>Acceptance of Terms</h2>
      <p>
        By using this website, you agree to these Terms of Service and all applicable laws.
      </p>

      <h2>Website Use</h2>
      <ul>
        <li>You may use this website for lawful business and informational purposes.</li>
        <li>You agree not to misuse, disrupt, or attempt unauthorized access to site systems.</li>
      </ul>

      <h2>Consulting Information</h2>
      <p>
        Content on this website is provided for general informational purposes and does not create a consulting engagement
        unless confirmed through a separate written agreement.
      </p>

      <h2>Intellectual Property</h2>
      <p>
        All content on this site, including text, branding, graphics, and layout, is owned by or licensed to MFD Research
        unless otherwise stated.
      </p>

      <h2>Third-Party Links</h2>
      <p>
        This website may include links to third-party websites. We are not responsible for third-party content,
        privacy practices, or availability.
      </p>

      <h2>Limitation of Liability</h2>
      <p>
        To the maximum extent allowed by law, MFD Research is not liable for indirect, incidental, or consequential
        damages arising from use of this website.
      </p>

      <h2>Changes to Terms</h2>
      <p>
        We may update these terms at any time. Continued use of the website after updates means you accept the revised terms.
      </p>

      <h2>Contact</h2>
      <p>
        Questions about these terms can be sent to <a href="mailto:info@mfdresearch.com">info@mfdresearch.com</a>.
      </p>

      <a class="home-btn" href="../">Back to Home</a>
    </article>
  </main>

</BaseLayout>

