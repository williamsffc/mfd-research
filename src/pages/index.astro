---
// Parity port of legacy static `index.html`.
// Static assets are served from `public/` (style.css, script.js, assets/, and root SEO/PWA files).
import { Fragment } from 'astro/jsx-runtime';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Conferences from '../components/Conferences.astro';
const web3formsAccessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ?? '';
---

<BaseLayout>
  <Fragment slot="head">
  <title>MFD Research | Where Expertise Meets Execution</title>
  <meta name="description"
    content="MFD Research delivers 18+ years of clinical research expertise, helping pharmaceutical organizations build world-class research sites from concept to completion." />
  <link rel="canonical" href="https://mfdresearch.com/" />
  <meta name="robots" content="index, follow" />
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; script-src 'self'; img-src 'self' data: https://mfdresearch.com; connect-src 'self' https://api.web3forms.com; form-action 'self' https://api.web3forms.com;" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://mfdresearch.com/" />
  <meta property="og:title" content="MFD Research | Where Expertise Meets Execution" />
  <meta property="og:description" content="MFD Research delivers 18+ years of clinical research expertise, helping pharmaceutical organizations build world-class research sites from concept to completion." />
  <meta property="og:image" content="https://mfdresearch.com/assets/og-image.png" />
  <meta property="og:site_name" content="MFD Research LLC" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="MFD Research | Where Expertise Meets Execution" />
  <meta name="twitter:description" content="MFD Research delivers 18+ years of clinical research expertise, helping pharmaceutical organizations build world-class research sites from concept to completion." />
  <meta name="twitter:image" content="https://mfdresearch.com/assets/og-image.png" />

  <!-- Favicons -->
  <link rel="icon" type="image/svg+xml" href="assets/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="assets/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="assets/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="assets/apple-touch-icon.png" />
  <link rel="manifest" href="site.webmanifest" />
  <link rel="stylesheet" href="style.css">
  </Fragment>

  <a href="#main-content" class="skip-link">Skip to main content</a>

  <!-- LOADER -->
  <div id="loader-overlay">
    <div class="loader-content">
      <div class="loader-text">MFD Research</div>
      <div class="loader-spinner"></div>
    </div>
  </div>

  <!-- NAV -->
  <Header />

  <!-- MAIN CONTENT -->
  <main id="main-content" tabindex="-1">

  <!-- HERO -->
  <section id="hero">
    <div class="hero-blob hero-blob-1"></div>
    <div class="hero-blob hero-blob-2"></div>
    <div class="hero-badge">
      <div class="hero-badge-dot"></div>
      Available for new partnerships
    </div>
    <div class="hero-content">
      <h1 class="hero-title">Clinical Research Operations<br />Built for <span>Execution</span></h1>
      <p class="hero-sub">MFD Research helps sponsors, CROs, biotech organizations, and research sites build, optimize, and strengthen clinical research operations from site development to inspection readiness.</p>
      <div class="hero-actions">
        <a href="https://calendar.app.google/8fQfrSyLumEMRKHQ9" class="btn-primary" target="_blank" rel="noopener noreferrer">Schedule a Confidential Consultation</a>
        <a href="#services" class="btn-secondary">View Consulting Services</a>
      </div>
    </div>

    <!-- Floating Card -->
    <div class="hero-card">
      <div class="hero-card-title">Core Expertise</div>
      <div class="hero-stat">
        <div class="hero-stat-icon" aria-hidden="true">🧬</div>
        <div>
          <div class="hero-stat-label">Experience</div>
          <div class="hero-stat-value" data-count="18" data-suffix="+ Years">18+ Years</div>
        </div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-icon" aria-hidden="true">📋</div>
        <div>
          <div class="hero-stat-label">Trial Phases</div>
          <div class="hero-stat-value">Phase I – III</div>
        </div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-icon" aria-hidden="true">🏥</div>
        <div>
          <div class="hero-stat-label">Specialties</div>
          <div class="hero-stat-value" data-count="10" data-suffix="+ Therapeutic Areas">10+ Therapeutic Areas</div>
        </div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-icon" aria-hidden="true">✅</div>
        <div>
          <div class="hero-stat-label">Certification</div>
          <div class="hero-stat-value">ACRP Certified CRC</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CREDIBILITY BAR -->
  <section id="credibility" aria-label="Key credentials at a glance">
    <div class="cred-inner">
      <div class="cred-item">
        <div class="cred-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
        <div>
          <div class="cred-value" data-count="18" data-suffix="+">18+</div>
          <div class="cred-text">Years of Experience</div>
        </div>
      </div>
      <div class="cred-item">
        <div class="cred-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
        <div>
          <div class="cred-value">Phase I–III</div>
          <div class="cred-text">Clinical Trials</div>
        </div>
      </div>
      <div class="cred-item">
        <div class="cred-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg></div>
        <div>
          <div class="cred-value">GCP Certified</div>
          <div class="cred-text">ICH Guidelines</div>
        </div>
      </div>
      <div class="cred-item">
        <div class="cred-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></div>
        <div>
          <div class="cred-value">Multi-Sponsor</div>
          <div class="cred-text">Portfolio Expertise</div>
        </div>
      </div>
      <div class="cred-item">
        <div class="cred-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg></div>
        <div>
          <div class="cred-value" data-count="10" data-suffix="+ Areas">10+ Areas</div>
          <div class="cred-text">Therapeutic Specialties</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about">
    <div class="about-grid">
      <div class="about-text">
        <div class="section-label reveal">Who We Are</div>
        <h2 class="section-title reveal reveal-delay-1">Strategic Partners in Clinical Excellence</h2>
        <p class="reveal reveal-delay-2">MFD Research is a specialized clinical research operations consulting firm helping sponsors, CROs, biotech organizations, and research sites strengthen operational execution, site readiness, quality systems, and trial delivery.</p>
        <p class="reveal reveal-delay-2">Founded by Michael Delgado, CCRC, the firm brings more than 18 years of hands-on clinical research leadership across site operations, sponsor partnerships, regulatory readiness, staff development, and multi-therapeutic trial execution.</p>
        <p class="reveal reveal-delay-3">Whether you’re building a new research capability or strengthening an existing program, we focus on practical, compliant execution—so your teams are ready to deliver with confidence.</p>
      </div>
      <div class="about-visual reveal reveal-delay-2">
        <div class="about-quote">"Building world-class clinical research operations requires both the science of
          compliance and the art of leadership."</div>
        <div class="about-author">— Founder &amp; Principal, MFD Research LLC</div>
        <div class="about-tags">
          <span class="about-tag">Site Development</span>
          <span class="about-tag">GCP Compliance</span>
          <span class="about-tag">Staff Training</span>
          <span class="about-tag">QMS Design</span>
          <span class="about-tag">Regulatory Strategy</span>
          <span class="about-tag">Trial Management</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services">
    <div class="section-label reveal">What We Do</div>
    <h2 class="section-title reveal reveal-delay-1">Consulting Services</h2>
    <p class="section-sub reveal reveal-delay-2">End-to-end clinical research consulting, from strategic planning to
      operational execution.</p>
    <div class="services-grid">
      <button class="service-card reveal reveal-delay-1" type="button" aria-expanded="false">
        <div class="service-card-inner">
          <div class="service-card-front">
            <div class="service-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg></div>
            <h3 class="service-title">Site Development &amp; Strategy</h3>
          </div>
          <div class="service-card-back">
            <p class="service-desc">We help organizations build research sites from the ground up, from site selection and infrastructure planning to sponsor activation and first patient enrollment.</p>
          </div>
        </div>
      </button>
      <button class="service-card reveal reveal-delay-2" type="button" aria-expanded="false">
        <div class="service-card-inner">
          <div class="service-card-front">
            <div class="service-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
            <h3 class="service-title">Regulatory Compliance &amp; GCP</h3>
          </div>
          <div class="service-card-back">
            <p class="service-desc">Proactive compliance strategies aligned with FDA, ICH-GCP, and sponsor requirements so your site stays inspection-ready at all times.</p>
          </div>
        </div>
      </button>
      <button class="service-card reveal reveal-delay-3" type="button" aria-expanded="false">
        <div class="service-card-inner">
          <div class="service-card-front">
            <div class="service-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></div>
            <h3 class="service-title">Quality Management Systems</h3>
          </div>
          <div class="service-card-back">
            <p class="service-desc">Design and implementation of robust QMS frameworks, including CAPA processes, deviation management, and internal audit programs.</p>
          </div>
        </div>
      </button>
      <button class="service-card reveal reveal-delay-1" type="button" aria-expanded="false">
        <div class="service-card-inner">
          <div class="service-card-front">
            <div class="service-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
            <h3 class="service-title">Multi-Specialty Trial Management</h3>
          </div>
          <div class="service-card-back">
            <p class="service-desc">Operational oversight across multiple therapeutic areas and concurrent trials with proven systems for complex, multi-protocol environments.</p>
          </div>
        </div>
      </button>
      <button class="service-card reveal reveal-delay-2" type="button" aria-expanded="false">
        <div class="service-card-inner">
          <div class="service-card-front">
            <div class="service-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
            <h3 class="service-title">Staff Training &amp; Development</h3>
          </div>
          <div class="service-card-back">
            <p class="service-desc">Customized training programs for research coordinators, sub-investigators, and site staff covering GCP fundamentals and protocol-specific procedures.</p>
          </div>
        </div>
      </button>
      <button class="service-card reveal reveal-delay-3" type="button" aria-expanded="false">
        <div class="service-card-inner">
          <div class="service-card-front">
            <div class="service-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></div>
            <h3 class="service-title">Operational Assessment &amp; Remediation</h3>
          </div>
          <div class="service-card-back">
            <p class="service-desc">Comprehensive site assessments that identify gaps in performance, compliance, and workflow, then turn them into actionable remediation plans.</p>
          </div>
        </div>
      </button>
    </div>
  </section>

  <!-- PROCESS -->
  <section id="process">
    <div class="section-label reveal">How We Work</div>
    <h2 class="section-title reveal reveal-delay-1">Our Engagement Process</h2>
    <p class="section-sub reveal reveal-delay-2">From first contact to final deliverable — a transparent, structured engagement model with no guesswork.</p>
    <div class="process-steps">
      <div class="process-step reveal reveal-delay-1">
        <div class="process-step-number" aria-hidden="true">01</div>
        <div class="process-step-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <h3 class="process-step-title">Discovery Call</h3>
        <p class="process-step-desc">A confidential 30-minute call to understand your goals, timelines, and challenges — no obligation, no pitch deck.</p>
      </div>
      <div class="process-connector" aria-hidden="true"></div>
      <div class="process-step reveal reveal-delay-2">
        <div class="process-step-number" aria-hidden="true">02</div>
        <div class="process-step-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </div>
        <h3 class="process-step-title">Assessment &amp; Proposal</h3>
        <p class="process-step-desc">We evaluate your current operations and deliver a tailored proposal — scope, timeline, and measurable outcomes clearly defined.</p>
      </div>
      <div class="process-connector" aria-hidden="true"></div>
      <div class="process-step reveal reveal-delay-3">
        <div class="process-step-number" aria-hidden="true">03</div>
        <div class="process-step-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <h3 class="process-step-title">Execution &amp; Delivery</h3>
        <p class="process-step-desc">Hands-on consulting with regular updates and clear milestones. We stay accountable until your operational goals are met.</p>
      </div>
    </div>
  </section>

  <!-- EXPERIENCE -->
  <section id="experience">
    <div class="section-label reveal">Operating Experience</div>
    <h2 class="section-title reveal reveal-delay-1">Founder-Led Operating Experience</h2>
    <p class="section-sub reveal reveal-delay-2">Practical clinical research leadership across site operations, sponsor engagement, quality systems, team development, and site strategy.</p>
    <div class="timeline">
      <div class="timeline-item">
        <div class="timeline-dot current"></div>
        <div class="timeline-year">2025–Present</div>
        <div class="timeline-role">Chief Clinical Officer</div>
        <div class="timeline-org">Ark Clinical Research</div>
        <div class="timeline-desc">Executive oversight of clinical operations across Ark sites, with focus on patient experience, study execution, enrollment performance, compliance, quality systems, team development, and strategic growth.</div>
      </div>
      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-year">2019–Present</div>
        <div class="timeline-role">Founder &amp; CEO</div>
        <div class="timeline-org">MFD Research</div>
        <div class="timeline-desc">Specialized consulting for research site development and strategy, helping partners build, strengthen, and optimize clinical research operations from concept through execution.</div>
      </div>
      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-year">2023–2025</div>
        <div class="timeline-role">Clinical Operations &amp; Therapeutic Program Leadership</div>
        <div class="timeline-org">Ark Clinical Research</div>
        <div class="timeline-desc">Operational leadership across clinical sites and metabolic/liver disease programs, including recruitment strategy, sponsor/CRO alignment, SOP development, staff mentorship, and scalable research execution.</div>
      </div>
      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-year">2017–2023</div>
        <div class="timeline-role">Site Operations Leadership</div>
        <div class="timeline-org">Velocity Clinical Research / Foothill Eye Institute</div>
        <div class="timeline-desc">Site-level leadership across high-volume research operations, study execution, regulatory readiness, sponsor relationships, quality processes, staff development, and operational improvement.</div>
      </div>
      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-year">2006–2017</div>
        <div class="timeline-role">Clinical Research Operations Foundation</div>
        <div class="timeline-org">Translational Research Group / Encino Research Center / NRI</div>
        <div class="timeline-desc">Built the site-level foundation behind MFD Research’s consulting approach through study coordination, patient-facing execution, Phase I-IV trial operations, regulatory documentation, GCP discipline, and multi-therapeutic research delivery.</div>
      </div>
    </div>
  </section>

  <!-- SPECIALTIES -->
  <section id="specialties">
    <div class="section-label reveal">Therapeutic Expertise</div>
    <h2 class="section-title reveal reveal-delay-1">Clinical Specialties</h2>
    <p class="section-sub reveal reveal-delay-2">Deep operational experience across a broad range of therapeutic areas
      and trial phases.</p>
    <div class="specialties-grid">
      <div class="specialty-group reveal reveal-delay-1">
        <div class="specialty-group-title"><span class="specialty-group-icon" aria-hidden="true">👁️</span> Ophthalmology</div>
        <div class="specialty-tags">
          <span class="specialty-tag">Glaucoma</span>
          <span class="specialty-tag">Dry Eye Disease</span>
          <span class="specialty-tag">AMD</span>
          <span class="specialty-tag">Retinopathy</span>
          <span class="specialty-tag">Ocular Inflammation</span>
          <span class="specialty-tag">Thyroid Eye Disease</span>
          <span class="specialty-tag">Presbyopia</span>
          <span class="specialty-tag">Post-Cataract Pain</span>
        </div>
      </div>
      <div class="specialty-group reveal reveal-delay-2">
        <div class="specialty-group-title"><span class="specialty-group-icon" aria-hidden="true">⚖️</span> Metabolic</div>
        <div class="specialty-tags">
          <span class="specialty-tag">Diabetes T1 & T2</span>
          <span class="specialty-tag">Obesity / Weight Loss</span>
          <span class="specialty-tag">NAFLD / NASH</span>
          <span class="specialty-tag">Hypercholesterolemia</span>
          <span class="specialty-tag">Obesity with CVD</span>
        </div>
      </div>
      <div class="specialty-group reveal reveal-delay-3">
        <div class="specialty-group-title"><span class="specialty-group-icon" aria-hidden="true">🫀</span> Cardiovascular</div>
        <div class="specialty-tags">
          <span class="specialty-tag">Hypertension</span>
          <span class="specialty-tag">Resistant Hypertension</span>
          <span class="specialty-tag">Hypotension</span>
        </div>
      </div>
      <div class="specialty-group reveal reveal-delay-4">
        <div class="specialty-group-title"><span class="specialty-group-icon" aria-hidden="true">🦠</span> Gastrointestinal</div>
        <div class="specialty-tags">
          <span class="specialty-tag">IBS-C / IBS-D</span>
          <span class="specialty-tag">GERD</span>
          <span class="specialty-tag">Chronic Constipation</span>
          <span class="specialty-tag">Opioid-Induced Constipation</span>
        </div>
      </div>
      <div class="specialty-group reveal reveal-delay-1">
        <div class="specialty-group-title"><span class="specialty-group-icon" aria-hidden="true">🧫</span> Dermatology</div>
        <div class="specialty-tags">
          <span class="specialty-tag">Psoriasis</span>
          <span class="specialty-tag">Acne</span>
          <span class="specialty-tag">Rosacea</span>
