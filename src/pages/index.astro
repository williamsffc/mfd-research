---
// Homepage: layout + SEO head; sections live in `src/components/` (migration Phase 8).
// Static assets: `public/` (style.css, script.js, assets/, SEO/PWA files).
import { Fragment } from 'astro/jsx-runtime';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageLoader from '../components/PageLoader.astro';
import Hero from '../components/Hero.astro';
import CredibilityBar from '../components/CredibilityBar.astro';
import WhoWeHelp from '../components/WhoWeHelp.astro';
import Services from '../components/Services.astro';
import EngagementProcess from '../components/EngagementProcess.astro';
import FounderExpertise from '../components/FounderExpertise.astro';
import TherapeuticExpertise from '../components/TherapeuticExpertise.astro';
import Credentials from '../components/Credentials.astro';
import Conferences from '../components/Conferences.astro';
import WhyMFD from '../components/WhyMFD.astro';
import Faq from '../components/Faq.astro';
import ContactCTA from '../components/ContactCTA.astro';

const web3formsAccessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ?? '';
---

<BaseLayout>
  <Fragment slot="head">
  <title>MFD Research | Where Expertise Meets Execution</title>
  <meta name="description"
    content="MFD Research delivers 18+ years of clinical research expertise, helping pharmaceutical organizations build world-class research sites from concept to completion." />
  <link rel="canonical" href="https://mfdresearch.com/" />
  <meta name="robots" content="index, follow" />
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; script-src 'self'; img-src 'self' data: https://mfdresearch.com; connect-src 'self' https://api.web3forms.com; form-action 'self' https://api.web3forms.com;" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://mfdresearch.com/" />
  <meta property="og:title" content="MFD Research | Where Expertise Meets Execution" />
  <meta property="og:description" content="MFD Research delivers 18+ years of clinical research expertise, helping pharmaceutical organizations build world-class research sites from concept to completion." />
  <meta property="og:image" content="https://mfdresearch.com/assets/og-image.png" />
  <meta property="og:site_name" content="MFD Research LLC" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="MFD Research | Where Expertise Meets Execution" />
  <meta name="twitter:description" content="MFD Research delivers 18+ years of clinical research expertise, helping pharmaceutical organizations build world-class research sites from concept to completion." />
  <meta name="twitter:image" content="https://mfdresearch.com/assets/og-image.png" />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://mfdresearch.com/#organization",
        "name": "MFD Research LLC",
        "url": "https://mfdresearch.com",
        "logo": {
          "@type": "ImageObject",
          "url": "https://mfdresearch.com/assets/favicon.svg"
        },
        "description": "MFD Research delivers 18+ years of clinical research expertise, helping pharmaceutical organizations build world-class research sites from concept to completion.",
        "email": "info@mfdresearch.com",
        "address": {
          "@type": "PostalAddress",
          "addressCountry": "US",
          "addressRegion": "CA"
        },
        "contactPoint": {
          "@type": "ContactPoint",
          "contactType": "Customer Service",
          "email": "info@mfdresearch.com",
          "availableLanguage": "English"
        },
        "sameAs": [
          "https://www.linkedin.com/in/mike-delgado/"
        ]
      },
      {
        "@type": "FAQPage",
        "@id": "https://mfdresearch.com/#faq",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What types of organizations do you work with?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "We work with pharmaceutical sponsors, biotech firms, CROs, and research sites of all sizes — from emerging Phase I sites to established multi-specialty networks. If you're building, optimizing, or remediating clinical research operations, we can help."
            }
          },
          {
            "@type": "Question",
            "name": "Do you work on a project or retainer basis?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Both. Short-term project engagements are available for defined deliverables such as SOP development, site assessments, or staff training programs. Ongoing advisory retainers are also available for organizations that need continuous operational support."
            }
          },
          {
            "@type": "Question",
            "name": "Are engagements confidential?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes — all client relationships are handled with complete professional discretion. We routinely sign mutual NDAs at the start of any engagement, and client details are never shared or referenced publicly."
            }
          },
          {
            "@type": "Question",
            "name": "Do you work with sites outside of California?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. While our founder is based in California, we support clients across the United States and can work remotely or on-site depending on the engagement type and client preference."
            }
          },
          {
            "@type": "Question",
            "name": "How quickly can an engagement begin?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Typically within 1–2 weeks of a signed agreement, depending on the scope of work. We understand that clinical research timelines are rarely forgiving, and we prioritize rapid mobilization for urgent site needs."
            }
          }
        ]
      }
    ]
  }
  </script>

  <!-- Favicons -->
  <link rel="icon" type="image/svg+xml" href="assets/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="assets/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="assets/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="assets/apple-touch-icon.png" />
  <link rel="manifest" href="site.webmanifest" />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&family=Instrument+Serif:ital@0;1&family=Space+Grotesk:wght@300..700&display=swap" crossorigin />
  <link rel="stylesheet" href="style.css">
  </Fragment>

  <a href="#main-content" class="skip-link">Skip to main content</a>

  <PageLoader />

  <Header />

  <main id="main-content" tabindex="-1">
    <Hero />
    <CredibilityBar />
    <WhoWeHelp />
    <Services />
    <EngagementProcess />
    <FounderExpertise />
    <TherapeuticExpertise />
    <Credentials />

    <section id="conferences">
      <Conferences />
    </section>

    <WhyMFD />
    <Faq />
    <ContactCTA web3formsAccessKey={web3formsAccessKey} />
  </main>

  <Footer />

  <button id="backToTop" class="back-to-top" aria-label="Back to top">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" aria-hidden="true" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"/></svg>
  </button>

  <script src="script.js" defer></script>

</BaseLayout>
