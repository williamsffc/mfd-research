---
import { services } from '../data/services';
---

<section id="services">
  <div class="section-label reveal">What We Do</div>
  <h2 class="section-title reveal reveal-delay-1">Consulting Services</h2>
  <p class="section-sub reveal reveal-delay-2">End-to-end clinical research consulting, from strategic planning to
    operational execution.</p>
  <div class="services-grid">
    {services.map((item, index) => {
      const panelId = `service-card-panel-${index + 1}`;
      const descId = `service-card-desc-${index + 1}`;
      return (
        <button class={`service-card reveal reveal-delay-${(index % 3) + 1}`} type="button" aria-expanded="false" aria-controls={panelId} aria-label={item.ariaLabel}>
          <div class="service-card-inner">
            <div class="service-card-front" data-service-front aria-hidden="false">
              <div class="service-icon" aria-hidden="true">
                <Fragment set:html={item.iconSvg} />
              </div>
              <h3 class="service-title">{item.title}</h3>
            </div>
            <div class="service-card-back" id={panelId} data-service-back aria-hidden="true">
              <p class="service-desc" id={descId}>{item.description}</p>
            </div>
          </div>
        </button>
      );
    })}
  </div>
</section>
