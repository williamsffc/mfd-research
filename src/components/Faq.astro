---
import { faqs } from '../data/faqs';
---

<section id="faq">
  <div class="section-label reveal">Common Questions</div>
  <h2 class="section-title reveal reveal-delay-1">Frequently Asked Questions</h2>
  <p class="section-sub reveal reveal-delay-2">Everything you need to know before reaching out.</p>
  <div class="faq-list reveal reveal-delay-2">
    {faqs.map((faq, index) => {
      const answerId = `faq-${index + 1}`;
      return (
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false" aria-controls={answerId}>
            {faq.question}
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer" id={answerId} hidden>
            <p>{faq.answer}</p>
          </div>
        </div>
      );
    })}
  </div>
</section>
