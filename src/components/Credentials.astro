---
import { credentials } from '../data/credentials';
---

<section id="credentials">
  <div class="section-label reveal">Certifications</div>
  <h2 class="section-title reveal reveal-delay-1">Credentials</h2>
  <p class="section-sub reveal reveal-delay-2">A commitment to continuous professional development across the full
    regulatory and clinical landscape.</p>
  <div class="creds-grid">
    {credentials.map((group, index) => (
      <div class={`reveal reveal-delay-${index + 1}`}>
        {group.title && <div class="creds-col-title">{group.title}</div>}
        {group.items.map(item => (
          <div class="cred-entry">
            <span class="cred-year-badge">{item.year}</span>
            <span class="cred-entry-text">{item.description}</span>
          </div>
        ))}
      </div>
    ))}
  </div>
</section>
