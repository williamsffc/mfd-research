---
export interface Props {
  web3formsAccessKey: string;
}
const { web3formsAccessKey } = Astro.props;
---

<section id="contact">
  <div class="contact-grid">
    <div>
      <div class="section-label reveal">Get In Touch</div>
      <h2 class="section-title reveal reveal-delay-1">Ready to Elevate Your Research Operations?</h2>
      <p class="section-sub contact-intro reveal reveal-delay-2">We welcome inquiries from
        pharmaceutical sponsors, biotech organizations, CROs, and emerging research sites. All consultations are
        confidential.</p>
      <div class="contact-info-block">
        <div class="contact-info-item reveal reveal-delay-2">
          <div class="contact-info-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div>
          <div>
            <div class="contact-info-label">Email</div>
            <div class="contact-info-value"><a href="mailto:info@mfdresearch.com">info@mfdresearch.com</a></div>
          </div>
        </div>
        <div class="contact-info-item reveal reveal-delay-3">
          <div class="contact-info-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div>
          <div>
            <div class="contact-info-label">Confidentiality</div>
            <div class="contact-info-value">All inquiries treated with strict confidentiality</div>
          </div>
        </div>
        <div class="contact-info-item reveal reveal-delay-4">
          <div class="contact-info-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
          <div>
            <div class="contact-info-label">Response Time</div>
            <div class="contact-info-value">We respond within 1–2 business days</div>
          </div>
        </div>
        <div class="contact-info-item reveal reveal-delay-4">
          <div class="contact-info-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg></div>
          <div>
            <div class="contact-info-label">LinkedIn</div>
            <div class="contact-info-value">
              <!-- UPDATE: Replace href with your LinkedIn profile or company page URL -->
              <a href="https://www.linkedin.com/in/mike-delgado/" target="_blank" rel="noopener noreferrer">Connect on LinkedIn</a>
            </div>
          </div>
        </div>
      </div>
      <!-- UPDATE: Replace href with your Calendly or booking link -->
      <a href="https://calendar.app.google/8fQfrSyLumEMRKHQ9" class="btn-schedule reveal reveal-delay-4" target="_blank" rel="noopener noreferrer">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Schedule a Confidential Consultation
      </a>
    </div>
    <div class="reveal reveal-delay-2">
      <form class="contact-form" action="https://api.web3forms.com/submit" method="POST" id="contact-form">
        <!-- Web3Forms Configuration -->
        <input type="hidden" name="access_key" value={web3formsAccessKey} />
        <input type="hidden" name="subject" value="New Contact Form Submission from MFD Research" />
        <input type="hidden" name="from_name" value="MFD Research Website" />
        <input type="checkbox" id="botcheck" name="botcheck" class="hidden" style="display: none;">

        <div class="form-row">
          <div class="form-group">
            <label for="fname">First Name</label>
            <input type="text" id="fname" name="first_name" placeholder="Jane" autocomplete="given-name" maxlength="80" required />
          </div>
          <div class="form-group">
            <label for="lname">Last Name</label>
            <input type="text" id="lname" name="last_name" placeholder="Smith" autocomplete="family-name" maxlength="80" required />
          </div>
        </div>
        <div class="form-group">
          <label for="email">Work Email</label>
        <input type="email" id="email" name="email" placeholder="jane@pharmacompany.com" autocomplete="email" inputmode="email" spellcheck="false" maxlength="254" required />
        </div>
        <div class="form-group">
          <label for="company">Company / Organization</label>
          <input type="text" id="company" name="company" placeholder="Pharma Corp" autocomplete="organization" maxlength="120" />
        </div>
        <div class="form-group">
          <label for="service">Area of Interest</label>
          <select id="service" name="service">
            <option value="">Select a service…</option>
            <option value="site-development">Site Development &amp; Strategy</option>
            <option value="regulatory-compliance">Regulatory Compliance &amp; GCP</option>
            <option value="quality-management">Quality Management Systems</option>
            <option value="trial-management">Multi-Specialty Trial Management</option>
            <option value="staff-training">Staff Training &amp; Development</option>
            <option value="operational-assessment">Operational Assessment &amp; Remediation</option>
            <option value="general">General Inquiry</option>
          </select>
        </div>
        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" maxlength="5000" required
            placeholder="Tell us about your research needs or project..." aria-describedby="message-count"></textarea>
          <div id="message-count" class="char-count" aria-live="polite">0 / 5000</div>
        </div>
        <button type="submit" class="form-submit">Send Message →</button>
      </form>
      <p id="contact-status" class="sr-only" aria-live="polite"></p>
    </div>
  </div>
</section>

