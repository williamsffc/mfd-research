---
const startYear = 2006;
const yearsExperience = new Date().getFullYear() - startYear;
---
<section id="hero">
  <div class="hero-blob hero-blob-1"></div>
  <div class="hero-blob hero-blob-2"></div>
  <div class="hero-content">
    <h1 class="hero-title">Clinical Research Operations<br />Built for <span>Execution</span></h1>
    <div class="hero-badge">
      <div class="hero-badge-dot"></div>
      Available for new partnerships
    </div>
    <p class="hero-sub">MFD Research helps sponsors, CROs, biotech organizations, and research sites build, optimize, and strengthen clinical research operations from site development to inspection readiness.</p>
    <div class="hero-actions">
      <a href="https://calendar.app.google/8fQfrSyLumEMRKHQ9" class="btn-primary" target="_blank" rel="noopener noreferrer">Schedule a Confidential Consultation</a>
      <a href="#services" class="btn-secondary">View Consulting Services</a>
    </div>
  </div>

  <!-- Floating Card -->
  <div class="hero-card">
    <div class="hero-card-title">Core Expertise</div>
    <div class="hero-stat">
      <div class="hero-stat-icon" aria-hidden="true">⏳</div>
      <div>
        <div class="hero-stat-label">Industry Experience</div>
        <div class="hero-stat-value" data-count={yearsExperience} data-suffix="+ Years">{yearsExperience}+ Years</div>
      </div>
    </div>
    <div class="hero-stat">
      <div class="hero-stat-icon" aria-hidden="true">📂</div>
      <div>
        <div class="hero-stat-label">Studies Supported</div>
        <div class="hero-stat-value" data-count="100" data-suffix="+">100+</div>
      </div>
    </div>
    <div class="hero-stat">
      <div class="hero-stat-icon" aria-hidden="true">📍</div>
      <div>
        <div class="hero-stat-label">Sites Activated</div>
        <div class="hero-stat-value" data-count="15" data-suffix="+">15+</div>
      </div>
    </div>
    <div class="hero-stat">
      <div class="hero-stat-icon" aria-hidden="true">🌍</div>
      <div>
        <div class="hero-stat-label">Trial Reach</div>
        <div class="hero-stat-value">Global</div>
      </div>
    </div>
  </div>
</section>
